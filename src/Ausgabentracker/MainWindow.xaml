<Window x:Class="Ausgabentracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Persönlicher Ausgaben-Tracker 💰" Height="500" Width="850" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Linke Seite: Formular -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Neue Ausgabe" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>
            <TextBlock Text="Betrag (CHF):" FontWeight="Bold"/>
            <TextBox x:Name="txtBetrag" Margin="0,5,0,15" Padding="5" FontSize="16"/>
            <TextBlock Text="Datum:" FontWeight="Bold"/>
            <DatePicker x:Name="dpDatum" Margin="0,5,0,15" SelectedDate="{x:Static sys:DateTime.Now}" />
            <TextBlock Text="Kategorie:" FontWeight="Bold"/>
            <ComboBox x:Name="cmbKategorie" Margin="0,5,0,15" Padding="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>
            <TextBlock Text="Notiz:" FontWeight="Bold"/>
            <TextBox x:Name="txtNotiz" Margin="0,5,0,20" Padding="5" Height="60" TextWrapping="Wrap"/>
            <Button x:Name="btnSpeichern" Content="💾 Speichern" Padding="10" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="BtnSpeichern_Click"/>
        </StackPanel>

        <!-- Rechte Seite: Liste & Statistik -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Transaktionen" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <ListView x:Name="lstAusgaben" Grid.Row="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Datum" DisplayMemberBinding="{Binding Datum, StringFormat=dd.MM.yyyy}" Width="90"/>
                        <GridViewColumn Header="Kategorie" DisplayMemberBinding="{Binding KategorieName}" Width="110"/>
                        <GridViewColumn Header="Notiz" DisplayMemberBinding="{Binding Notiz}" Width="140"/>
                        <GridViewColumn Header="Betrag" DisplayMemberBinding="{Binding Betrag, StringFormat=\{0:N2\} CHF}" Width="90"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- NEU: Summe und Löschen -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,15,0,0">
                <Button x:Name="btnLoeschen" Content="🗑️ Eintrag löschen" Background="#f44336" Foreground="White" Padding="10,5" Click="BtnLoeschen_Click"/>
                <TextBlock Text="Gesamtausgaben:" Margin="150,0,10,0" VerticalAlignment="Center" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="lblGesamtSumme" Text="0.00 CHF" VerticalAlignment="Center" FontSize="18" FontWeight="Bold" Foreground="Red"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>