<Window x:Class="Ausgabentracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Persönlicher Ausgaben-Tracker" Height="640" Width="1040" MinHeight="580" MinWidth="940"
        WindowStartupLocation="CenterScreen" Background="#F4F6F8">

    <Window.Resources>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#24313F"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderBrush" Value="#CCD5DF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="BorderBrush" Value="#CCD5DF"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="Foreground" Value="#24313F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#176B87"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E8EEF3"/>
            <Setter Property="Foreground" Value="#24313F"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#B42318"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="LeftColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="RightColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="22" BorderBrush="#D8E0E7" BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="txtFormularTitel" Text="Neue Transaktion" FontSize="24" FontWeight="Bold" Foreground="#17212B" Margin="0,0,0,4"/>
                <Rectangle Height="2" Fill="#E8EEF3" Margin="0,14,0,22"/>

                <TextBlock Text="Typ" Style="{StaticResource LabelText}"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                    <RadioButton x:Name="rbAusgabe" Content="Ausgabe" IsChecked="True"/>
                    <RadioButton x:Name="rbEinnahme" Content="Einnahme"/>
                </StackPanel>

                <TextBlock Text="Betrag (CHF)" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="txtBetrag"/>

                <TextBlock Text="Datum" Style="{StaticResource LabelText}"/>
                <DatePicker x:Name="dpDatum" SelectedDate="{x:Static sys:DateTime.Now}" />

                <TextBlock Text="Kategorie" Style="{StaticResource LabelText}"/>
                <ComboBox x:Name="cmbKategorie" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                <TextBlock Text="Notiz" Style="{StaticResource LabelText}"/>
                <TextBox x:Name="txtNotiz" Height="92" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <Button x:Name="btnSpeichern" Content="Speichern" Style="{StaticResource PrimaryButton}" Click="BtnSpeichern_Click"/>
                <Button x:Name="btnAbbrechen" Content="Abbrechen" Style="{StaticResource SecondaryButton}" Margin="0,10,0,0"
                        Visibility="Collapsed" Click="BtnAbbrechen_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock DockPanel.Dock="Left" Text="Transaktionen" FontSize="24" FontWeight="Bold" Foreground="#17212B"
                           VerticalAlignment="Center"/>

                <UniformGrid DockPanel.Dock="Right" Columns="3" Width="480" VerticalAlignment="Center">
                    <Border Style="{StaticResource SummaryCard}" Background="#EAF8EF" BorderBrush="#B7E4C7">
                        <StackPanel>
                            <TextBlock Text="Einnahmen" FontSize="12" Foreground="#166534"/>
                            <TextBlock x:Name="lblGesamtEinnahmen" Text="0.00 CHF" FontSize="18" FontWeight="Bold" Foreground="#15803D"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="#FFF1F0" BorderBrush="#F4B4AD">
                        <StackPanel>
                            <TextBlock Text="Ausgaben" FontSize="12" Foreground="#7F1D1D"/>
                            <TextBlock x:Name="lblGesamtAusgaben" Text="0.00 CHF" FontSize="18" FontWeight="Bold" Foreground="#B42318"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryCard}" Background="#EEF4FF" BorderBrush="#B8CDF8">
                        <StackPanel>
                            <TextBlock Text="Saldo" FontSize="12" Foreground="#1E3A8A"/>
                            <TextBlock x:Name="lblSaldo" Text="0.00 CHF" FontSize="18" FontWeight="Bold" Foreground="#1D4ED8"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </DockPanel>

            <Border Grid.Row="1" Background="White" CornerRadius="8" BorderBrush="#D8E0E7" BorderThickness="1">
                <ListView x:Name="lstAusgaben" BorderThickness="0" SelectionChanged="LstAusgaben_SelectionChanged">
                    <ListView.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="#F4F6F8" BorderBrush="#D8E0E7" BorderThickness="0,1,0,1" Padding="12,8">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#17212B"/>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListView.GroupStyle>
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Typ" Width="95" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Typ}" Foreground="{Binding BetragFarbe}" FontWeight="SemiBold" Padding="4,0"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Datum" Width="105" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Datum, StringFormat=dd.MM.yyyy}" HorizontalAlignment="Left" Padding="4,0"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Kategorie" Width="130" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding KategorieName}" HorizontalAlignment="Left" Padding="4,0"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Notiz" Width="230" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Notiz}" HorizontalAlignment="Left" Padding="4,0" TextTrimming="CharacterEllipsis"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Betrag" Width="120" HeaderContainerStyle="{StaticResource RightColumnHeader}">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding BetragAnzeige}" Foreground="{Binding BetragFarbe}" FontWeight="SemiBold"
                                                   HorizontalAlignment="Stretch" TextAlignment="Right" Padding="4,0"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <DockPanel Grid.Row="2" Margin="0,14,0,0">
                <Button x:Name="btnExportExcel" DockPanel.Dock="Left" Content="Excel exportieren"
                        Style="{StaticResource SecondaryButton}" Click="BtnExportExcel_Click"/>
                <Button x:Name="btnLoeschen" DockPanel.Dock="Right" Content="Transaktion löschen"
                        Style="{StaticResource DangerButton}" Click="BtnLoeschen_Click"/>
            </DockPanel>
        </Grid>
    </Grid>
</Window>
