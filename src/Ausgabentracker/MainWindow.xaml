<Window x:Class="Ausgabentracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Persönlicher Ausgaben-Tracker" Height="720" Width="1180" MinHeight="640" MinWidth="1060"
        WindowStartupLocation="CenterScreen" Background="#EFF3F6"
        FontFamily="Segoe UI" FontSize="14" UseLayoutRounding="True">

    <Window.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SoftSurfaceBrush" Color="#F8FAFC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#15202B"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="BorderBrushLight" Color="#D9E2EA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0F6C81"/>
        <SolidColorBrush x:Key="IncomeBrush" Color="#167A42"/>
        <SolidColorBrush x:Key="ExpenseBrush" Color="#B42318"/>
        <SolidColorBrush x:Key="BalanceBrush" Color="#1D4ED8"/>

        <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="2" Direction="270" Opacity="0.14" Color="#1E293B"/>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="Margin" Value="0,0,0,7"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="FieldBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FieldBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="FieldBorder" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushLight}"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RadioButton}">
                        <Border x:Name="RadioBorder"
                                Background="#F3F7FA"
                                BorderBrush="{StaticResource BorderBrushLight}"
                                BorderThickness="1"
                                CornerRadius="7"
                                Padding="14,9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RadioBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RadioBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="130"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E6EEF3"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{StaticResource ExpenseBrush}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="8,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="BorderBrush" Value="#EEF2F6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3F8FB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E1F0F4"/>
                    <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LeftColumnHeader" TargetType="GridViewColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource SoftSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#E5ECF2"/>
        </Style>

        <Style x:Key="RightColumnHeader" TargetType="GridViewColumnHeader" BasedOn="{StaticResource LeftColumnHeader}">
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>

        <Style x:Key="SummaryCard" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,22">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Persönlicher Ausgaben-Tracker"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Einnahmen, Ausgaben und Saldo in einer klaren Übersicht"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="2,4,0,0"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="btnExportExcel"
                        Content="Excel exportieren"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,10,0"
                        Click="BtnExportExcel_Click"/>
                <Button x:Name="btnLoeschen"
                        Content="Transaktion löschen"
                        Style="{StaticResource DangerButton}"
                        Click="BtnLoeschen_Click"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceBrush}"
                    CornerRadius="8"
                    Padding="24"
                    BorderBrush="{StaticResource BorderBrushLight}"
                    BorderThickness="1"
                    Effect="{StaticResource SoftShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="txtFormularTitel"
                                   Text="Neue Transaktion"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="Erfasse einen neuen Eintrag oder bearbeite die ausgewählte Transaktion."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="Typ" Style="{StaticResource LabelText}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <RadioButton x:Name="rbAusgabe" GroupName="TransactionType" Content="Ausgabe" IsChecked="True"/>
                            <RadioButton x:Name="rbEinnahme" GroupName="TransactionType" Content="Einnahme"/>
                        </StackPanel>

                        <TextBlock Text="Betrag (CHF)" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="txtBetrag"/>

                        <TextBlock Text="Datum" Style="{StaticResource LabelText}"/>
                        <DatePicker x:Name="dpDatum" SelectedDate="{x:Static sys:DateTime.Now}"/>

                        <TextBlock Text="Kategorie" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="cmbKategorie" DisplayMemberPath="Name" SelectedValuePath="Id"/>

                        <TextBlock Text="Notiz" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="txtNotiz"
                                 Height="96"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"/>

                        <Button x:Name="btnSpeichern"
                                Content="Speichern"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnSpeichern_Click"/>
                        <Button x:Name="btnAbbrechen"
                                Content="Abbrechen"
                                Style="{StaticResource SecondaryButton}"
                                Margin="0,10,0,0"
                                Visibility="Collapsed"
                                Click="BtnAbbrechen_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="3" Margin="0,0,0,18">
                    <Border Style="{StaticResource SummaryCard}" Background="#EDF8F1" BorderBrush="#BCE5CB">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Einnahmen" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource IncomeBrush}"/>
                            <TextBlock x:Name="lblGesamtEinnahmen"
                                       Grid.Row="1"
                                       Text="0.00 CHF"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource IncomeBrush}"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SummaryCard}" Background="#FFF1F0" BorderBrush="#F2B8B2">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Ausgaben" FontSize="12" FontWeight="SemiBold" Foreground="#8F1B12"/>
                            <TextBlock x:Name="lblGesamtAusgaben"
                                       Grid.Row="1"
                                       Text="0.00 CHF"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ExpenseBrush}"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource SummaryCard}" Background="#EEF4FF" BorderBrush="#B8CDF8" Margin="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Saldo" FontSize="12" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                            <TextBlock x:Name="lblSaldo"
                                       Grid.Row="1"
                                       Text="0.00 CHF"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource BalanceBrush}"
                                       Margin="0,4,0,0"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="1"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8"
                        BorderBrush="{StaticResource BorderBrushLight}"
                        BorderThickness="1"
                        Effect="{StaticResource SoftShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Margin="18,16,18,12">
                            <TextBlock DockPanel.Dock="Left"
                                       Text="Transaktionen"
                                       Style="{StaticResource SectionTitle}"
                                       VerticalAlignment="Center"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="Nach Monat gruppiert"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <ListView x:Name="lstAusgaben"
                                  Grid.Row="1"
                                  BorderThickness="0"
                                  Background="Transparent"
                                  SelectionChanged="LstAusgaben_SelectionChanged"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListView.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Background="#F2F6F9"
                                                    BorderBrush="#E0E8EF"
                                                    BorderThickness="0,1,0,1"
                                                    Padding="16,9">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListView.GroupStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Typ" Width="88" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Typ}"
                                                           Foreground="{Binding BetragFarbe}"
                                                           FontWeight="SemiBold"
                                                           Padding="6,0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Datum" Width="104" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Datum, StringFormat=dd.MM.yyyy}" Padding="6,0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Kategorie" Width="136" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding KategorieName}" Padding="6,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Notiz" Width="260" HeaderContainerStyle="{StaticResource LeftColumnHeader}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Notiz}" Padding="6,0" TextTrimming="CharacterEllipsis"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Header="Betrag" Width="128" HeaderContainerStyle="{StaticResource RightColumnHeader}">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding BetragAnzeige}"
                                                           Foreground="{Binding BetragFarbe}"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Stretch"
                                                           TextAlignment="Right"
                                                           Padding="6,0"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
