<Window x:Class="Ausgabentracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Persönlicher Ausgaben-Tracker 💰" Height="450" Width="800" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LINKE SEITE: Eingabeformular -->
        <StackPanel Grid.Column="0" Margin="0,0,20,0">
            <TextBlock Text="Neue Ausgabe erfassen" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Betrag (CHF):" FontWeight="SemiBold"/>
            <TextBox x:Name="txtBetrag" Margin="0,5,0,15" Padding="5" FontSize="16"/>

            <TextBlock Text="Datum:" FontWeight="SemiBold"/>
            <DatePicker x:Name="dpDatum" Margin="0,5,0,15" Padding="5" SelectedDate="{x:Static sys:DateTime.Now}" />

            <TextBlock Text="Kategorie:" FontWeight="SemiBold"/>

            <!-- HIER IST DAS FEHLENDE DROPDOWN! -->
            <ComboBox x:Name="cmbKategorie" Margin="0,5,0,15" Padding="5" DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Text="Notiz / Beschreibung:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtNotiz" Margin="0,5,0,20" Padding="5" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

            <Button x:Name="btnSpeichern" Content="💾 Speichern" Padding="10" FontSize="16" Background="#4CAF50" Foreground="White" FontWeight="Bold" Click="BtnSpeichern_Click"/>
        </StackPanel>

        <!-- RECHTE SEITE: Liste der Ausgaben -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Letzte Transaktionen" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

            <ListView x:Name="lstAusgaben" Grid.Row="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Datum" DisplayMemberBinding="{Binding Datum, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <GridViewColumn Header="Kategorie" DisplayMemberBinding="{Binding KategorieName}" Width="120"/>
                        <GridViewColumn Header="Notiz" DisplayMemberBinding="{Binding Notiz}" Width="150"/>
                        <GridViewColumn Header="Betrag" DisplayMemberBinding="{Binding Betrag, StringFormat=\{0:N2\} CHF}" Width="100"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</Window>